{% extends 'base.html.twig' %}
{% block title %}Proposition - {{ proposition.chantier }}{% endblock %}
{% block body %}
<h2>{{ proposition.chantier }}</h2>
<span class="badge bg-{% if proposition.statut == 'envoye' %}warning{% elseif proposition.statut == 'accepte' %}info{% elseif proposition.statut == 'devis_soumis' %}success{% else %}secondary{% endif %} mb-3">{{ proposition.statut }}</span>

<div class="card mb-3"><div class="card-body">
    <h5>Devis type du chantier</h5>
    <p><strong>Bien :</strong> {{ proposition.chantier.bien }}</p>
    <table class="table table-sm">
        <thead><tr><th>Prestation</th><th>Catégorie</th><th>Qté</th><th>PU</th><th>Total</th></tr></thead>
        <tbody>
        {% set total = 0 %}
        {% for l in proposition.chantier.lignesDevis %}
            {% set lt = l.prestation.prixUnitaire * l.quantite %}
            <tr>
                <td>{{ l.prestation }}</td>
                <td>{{ l.prestation.categorie }}</td>
                <td>{{ l.quantite }}</td>
                <td>{{ l.prestation.prixUnitaire }} €</td>
                <td>{{ lt }} €</td>
            </tr>
            {% set total = total + lt %}
        {% endfor %}
        </tbody>
        <tfoot><tr><th colspan="4">Total estimé</th><th>{{ total }} €</th></tr></tfoot>
    </table>
</div></div>

{% if proposition.statut == 'envoye' %}
<div class="card p-3 mb-3">
    <h5>Répondre à la proposition</h5>
    <form method="post" action="{{ path('entrepreneur_repondre', {id: proposition.id}) }}" class="d-flex gap-2">
        <button name="action" value="accepter" class="btn btn-success">Accepter</button>
        <button name="action" value="refuser" class="btn btn-danger">Refuser</button>
    </form>
</div>
{% endif %}

{% if proposition.statut == 'accepte' and not devis %}
<div class="card p-3 mb-3">
    <h5>Soumettre mon devis</h5>
    <form method="post" action="{{ path('entrepreneur_soumettre_devis', {id: proposition.id}) }}" enctype="multipart/form-data">
        <div class="row g-2 mb-2">
            <div class="col"><input type="number" step="0.01" name="prix_total" class="form-control" placeholder="Prix total (€)" required></div>
            <div class="col"><input type="date" name="date_debut" class="form-control" required></div>
        </div>
        <input type="file" name="fichier_pdf" class="form-control mb-2" accept=".pdf">
        <button class="btn btn-primary">Soumettre</button>
    </form>
</div>
{% endif %}

{% if devis %}
<div class="alert alert-success">
    <strong>Devis soumis :</strong> {{ devis.prixTotal }} € - Début travaux : {{ devis.dateDebutTravaux|date('d/m/Y') }}
    {% if devis.fichierPdf %}<a href="/uploads/devis/{{ devis.fichierPdf }}" target="_blank" class="ms-2">Voir PDF</a>{% endif %}
</div>

<div class="card p-3 mb-3">
    <h5>Suivi d'avancement</h5>
    {% for av in avancements %}
        <div class="border-bottom pb-2 mb-2">
            <strong>{{ av.pourcentage }}%</strong> - {{ av.description }}
            <small class="text-muted">{{ av.createdAt|date('d/m/Y H:i') }}</small>
            {% for p in av.photos %}
                <img src="/uploads/photos/{{ p.fichier }}" class="d-block mt-1" style="max-width:200px">
            {% endfor %}
        </div>
    {% endfor %}
    <form method="post" action="{{ path('entrepreneur_avancement', {id: proposition.id}) }}" enctype="multipart/form-data" class="mt-3">
        <div class="row g-2 mb-2">
            <div class="col-md-2"><input type="number" name="pourcentage" class="form-control" placeholder="%" min="0" max="100" required></div>
            <div class="col"><input type="text" name="description" class="form-control" placeholder="Description" required></div>
        </div>
        <input type="file" name="photo" class="form-control mb-2" accept="image/*">
        <button class="btn btn-outline-primary btn-sm">Ajouter avancement</button>
    </form>
</div>
{% endif %}
{% endblock %}
