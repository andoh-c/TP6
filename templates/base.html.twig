<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}GestTravaux{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
    {% block stylesheets %}{% endblock %}
</head>
<body>
{% if app.user %}
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_home') }}">GestTravaux</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav">
            <ul class="navbar-nav me-auto">
                {% if is_granted('ROLE_ADMIN') %}
                    <li class="nav-item"><a class="nav-link" href="{{ path('admin_chantiers') }}">Chantiers</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('admin_users') }}">Utilisateurs</a></li>
                {% endif %}
                {% if is_granted('ROLE_INSPECTEUR') %}
                    <li class="nav-item"><a class="nav-link" href="{{ path('inspecteur_dashboard') }}">Mes chantiers</a></li>
                {% endif %}
                {% if is_granted('ROLE_ENTREPRENEUR') %}
                    <li class="nav-item"><a class="nav-link" href="{{ path('entrepreneur_dashboard') }}">Mes propositions</a></li>
                {% endif %}
                {% if is_granted('ROLE_PROPRIETAIRE') %}
                    <li class="nav-item"><a class="nav-link" href="{{ path('proprietaire_dashboard') }}">Mes biens</a></li>
                {% endif %}
            </ul>
            <ul class="navbar-nav">
                <li class="nav-item"><span class="nav-link text-light">{{ app.user.nom }}</span></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_logout') }}">Déconnexion</a></li>
            </ul>
        </div>
    </div>
</nav>
{% endif %}
<div class="container">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show">
                {{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}
    {% block body %}{% endblock %}
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
